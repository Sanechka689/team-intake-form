# Core links for UI buttons
LINK_FOLDER=https://drive.google.com/drive/folders/your_folder_id
LINK_CHEATSHEET=https://docs.google.com/document/d/your_cheatsheet_id/edit
LINK_TABLE=https://docs.google.com/spreadsheets/d/your_sheet_id/edit
LINK_INSTRUCTION=https://docs.google.com/document/d/your_instruction_id/edit
LINK_ASK_QUESTION=https://t.me/your_contact_or_chat

# Option A (recommended): Google Apps Script webhook
GOOGLE_APPS_SCRIPT_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec
GOOGLE_APPS_SCRIPT_SECRET=replace_with_same_secret_as_WEBHOOK_SECRET

# Option B (fallback): direct Google Sheets API with service account
GOOGLE_CLIENT_EMAIL=service-account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_SHEET_ID=your_sheet_id
SHEET_PARTICIPANTS_TAB=Анкеты участников
SHEET_AUDIT_TAB=audit_log
SHEET_FIELD_KEY_ROW=2
SHEET_DATA_START_ROW=3

# Anti-spam / rate limit
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=8
