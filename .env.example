APP_SECRET=replace_with_long_private_token
DEFAULT_FORM_PATH=/s/replace_with_long_private_token

# Option A (recommended): Google Apps Script webhook
GOOGLE_APPS_SCRIPT_URL=https://script.google.com/macros/s/PASTE_DEPLOYMENT_ID/exec
GOOGLE_APPS_SCRIPT_SECRET=replace_with_same_WEBHOOK_SECRET_from_apps_script

# Option B (legacy): direct Google service account (optional)
GOOGLE_CLIENT_EMAIL=service-account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_SHEET_ID=spreadsheet_id_here
SHEET_PARTICIPANTS_TAB=Анкеты участников
SHEET_AUDIT_TAB=audit_log

RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=8

LINK_FOLDER=https://drive.google.com/drive/folders/your_folder
LINK_CHEATSHEET=https://docs.google.com/document/d/your_cheatsheet
LINK_TABLE=https://docs.google.com/spreadsheets/d/your_sheet
LINK_INSTRUCTION=https://docs.google.com/document/d/your_instruction
LINK_QUESTIONS=https://docs.google.com/spreadsheets/d/your_sheet#gid=questions
